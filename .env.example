# LLM provider: "lm_studio" (OpenAI-compatible HTTP) or "claude_cli" (claude -p subprocess)
LLM_PROVIDER=lm_studio

# LM Studio / OpenAI-compatible endpoint (required when LLM_PROVIDER=lm_studio)
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen2.5-7b-instruct
LLM_API_KEY=lm-studio
LLM_TIMEOUT_SECONDS=3600

# Claude CLI backend (used when LLM_PROVIDER=claude_cli)
# CLAUDE_CLI_BIN=claude
# CLAUDE_CLI_MODEL=sonnet
# CLAUDE_CLI_TIMEOUT_SECONDS=600

# Backend bind
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Logging
LOG_LEVEL=INFO

# When true (default), wipe ~/.bob/bob.db at each server start (fresh Jarvis
# thread + empty tasks). Set to "false" to keep state across restarts.
BOB_CLEAR_ON_START=true

# Tavily web search — backs the web_search / web_fetch tools. Free-tier key
# from https://app.tavily.com. Leave blank to disable web search (the tool
# then returns an actionable error asking the user to set this).
TAVILY_API_KEY=
