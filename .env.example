# LLM provider: "lm_studio" (OpenAI-compatible HTTP) or "claude_cli" (claude -p subprocess)
LLM_PROVIDER=lm_studio

# LM Studio / OpenAI-compatible endpoint (required when LLM_PROVIDER=lm_studio)
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen2.5-7b-instruct
LLM_API_KEY=lm-studio
LLM_TIMEOUT_SECONDS=3600

# Claude CLI backend (used when LLM_PROVIDER=claude_cli)
# CLAUDE_CLI_BIN=claude
# CLAUDE_CLI_MODEL=sonnet
# CLAUDE_CLI_TIMEOUT_SECONDS=600

# Backend bind
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# STT engine — la « Listen » spine. "whisper_cpp" (défaut, large-v3-turbo via
# pywhispercpp, Metal/CoreML) re-décode un buffer glissant. "sherpa" = transducer
# zipformer true-streaming (sherpa-onnx) : tokens au fil de l'audio, latence plus
# basse, pas de re-décode. dev.sh pose l'extra "stt-sherpa" automatiquement quand
# STT_ENGINE=sherpa. Modèle FR auto-téléchargé dans ~/.cache/bob/sherpa au 1er
# usage si STT_SHERPA_MODEL_DIR vide. Note : le wake word « Yo Bob » ne tourne
# que sur le chemin whisper_cpp.
# STT_ENGINE=whisper_cpp
# STT_SHERPA_MODEL_DIR=
# STT_SHERPA_INT8=true

# Logging
LOG_LEVEL=INFO

# When true (default), wipe ~/.bob/bob.db at each server start (fresh Jarvis
# thread + empty tasks). Set to "false" to keep state across restarts.
BOB_CLEAR_ON_START=true

# Tavily web search — backs the web_search / web_fetch tools. Free-tier key
# from https://app.tavily.com. Leave blank to disable web search (the tool
# then returns an actionable error asking the user to set this).
TAVILY_API_KEY=

# MCP server manifest (PRD 0015 / issue 0094). Config-driven list of MCP servers
# Bob connects to as a *client* at boot, discovering + curating their tools — a
# developer branches a new tool by adding an entry here, no code. Optional and
# boot-green: leave unset (or "[]") for no MCP tools; a down/absent server is
# logged and registers nothing while its peers register normally. JSON list; per
# server: name, transport ("stdio"|"http"), command/args or url, env, an
# "expose" tool allowlist, and per-tool "tools" overrides (description_fr, args
# subset, tags for retrieval, terminal). Example (one stdio weather server —
# the issue 0095 acceptance case: a single-shot forecast tool narrowed to
# place + date, French description, weather retrieval tags, terminal lookup):
# MCP_SERVERS=[{"name":"weather","transport":"stdio","command":"uvx","args":["weather-mcp"],"expose":["get_forecast"],"tools":{"get_forecast":{"description_fr":"Donne la météo (prévision) pour un lieu et une date.","args":["place","date"],"tags":["météo","weather","temps","prévision"],"terminal":true}}}]
# MCP_SERVERS=[]
# MCP_CALL_TIMEOUT_SECONDS=30
